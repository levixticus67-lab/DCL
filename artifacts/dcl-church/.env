# Frontend environment variables for the DCL Church web app.
# Used for LOCAL development only.
# For production, these are set as GitHub Secrets and baked in at build time.

# --- Backend API ---
# The full URL of your deployed Render backend (no trailing slash).
VITE_API_BASE_URL=https://dcl-api-kz7r.onrender.com

# --- Firebase Web SDK ---
# Get from Firebase Console -> Project settings -> Your apps -> Web app
VITE_FIREBASE_API_KEY=AIzaSyAQWvpD7EEuyNaE1RUwDBDgEdprIGCm27g
VITE_FIREBASE_AUTH_DOMAIN=dcl-church.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=dcl-church
VITE_FIREBASE_APP_ID=1:384171384743:web:59e9cae8ff2286a212a082

# --- Firebase Storage ---
# Get from Firebase Console -> Project settings -> Your apps -> Web app
# Usually: your-project-id.firebasestorage.app
VITE_FIREBASE_STORAGE_BUCKET=dcl-church.firebasestorage.app
